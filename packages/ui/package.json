{
	"name": "@zapn/ui",
	"version": "0.0.0",
	"private": true,
	"exports": {
    "./styles.css": "./dist/index.css",
		"./*": "./src/components/*.tsx",
		"./epg": "./src/epg/index.tsx"
	},
	"scripts": {
    "build": "tailwindcss -i ./src/styles.css -o ./dist/index.css",
    "dev": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
		"lint": "biome check --write",
		"generate:component": "turbo gen react-component",
		"check-types": "tsc --noEmit"
	},
	"devDependencies": {
		"@zapn/biome-config": "workspace:^",
		"@zapn/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.2.2",
		"@types/node": "^22.15.3",
		"@types/react": "19.2.2",
		"@types/react-dom": "19.2.2",
		"typescript": "5.9.2"
	},
	"dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
		"planby": "^2.0.0",
    "radix-ui": "^1.4.3",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
	}
}
