---
import EPG from "@zapn/ui/epg";

import Layout from "@/layouts/Layout.astro";
import { repository } from "@/lib/epg";

const guide = await repository.getGuide();

if (!guide) {
  return new Response(null, {
    status: 404,
  });
}
---
<Layout>
  <main>
    <EPG
      client:load
      channels={guide.channels}
      programs={guide.programs}
      style={{ height: "100dvh", width: "100dvw" }}
    />
  </main>
</Layout>
